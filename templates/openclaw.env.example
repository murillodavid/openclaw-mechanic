# Example environment file for a forked OpenClaw deployment.

OPENCLAW_HOST=your-openclaw-host.example.com
OPENCLAW_PORT=19089
OPENCLAW_BASE_URL=https://your-openclaw-host.example.com
OPENCLAW_GATEWAY_TOKEN=replace_me
OPENCLAW_SSH_TARGET=your-user@your-openclaw-host.example.com
OPENCLAW_CONFIG_PATH=/path/to/your/openclaw.json
OPENCLAW_LOG_LEVEL=info
